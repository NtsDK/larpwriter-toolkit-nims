# ===== HTTP =====
server {
    listen 80;
    server_name ${DOMAINS};

    ${SSL_REDIRECT_BLOCK}

    location / {
        proxy_pass http://app:3001;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}

# ===== HTTPS (только если включён SSL) =====
${HTTPS_BLOCK}